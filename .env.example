# Copiar este archivo como .env y completar con los datos reales
# NUNCA commitear el archivo .env al repositorio

# URL del sistema Orion Contact Center
ORION_BASE_URL=http://your-orion-url.com

# Credenciales de usuario administrador
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_password

# Credenciales de usuario supervisor
SUPERVISOR_USERNAME=supervisor
SUPERVISOR_PASSWORD=your_password

# Credenciales de usuario agente
AGENT_USERNAME=agente01
AGENT_PASSWORD=your_password

# Configuracion del browser
BROWSER=chromium
HEADLESS=false
SLOW_MO=0

# Timeouts (en milisegundos)
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
